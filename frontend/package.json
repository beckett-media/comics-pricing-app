{
  "name": "frontend",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint --max-warnings 0 --ext .js,.ts,.tsx . && tsc --noEmit",
    "pretty": "prettier --write ."
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "jsxSingleQuote": false,
    "printWidth": 100,
    "quoteProps": "as-needed",
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@types/eslint": "^7.28.2"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^2.18.3",
    "@chakra-ui/react": "^2.1.2",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@fortawesome/fontawesome-free": "^6.1.1",
    "@nivo/core": "^0.79.0",
    "@nivo/line": "^0.79.1",
    "@nivo/scatterplot": "^0.79.1",
    "@types/d3": "^7.1.0",
    "@types/react-virtualized": "^9.21.21",
    "algoliasearch": "^4.13.0",
    "aws-amplify": "^4.3.24",
    "axios": "^0.27.2",
    "framer-motion": "^6",
    "js-cookie": "^3.0.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-hot-toast": "^2.2.0",
    "react-icons": "^4.4.0",
    "react-instantsearch-hooks-web": "^6.24.2",
    "react-router-dom": "^6.3.0",
    "react-virtualized": "^9.22.3",
    "swr": "^1.3.0"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.2",
    "@types/node": "^17.0.21",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.13",
    "autoprefixer": "^10.4.2",
    "postcss": "^8.4.7",
    "prettier": "^2.5.1",
    "prettier-plugin-tailwindcss": "^0.1.11",
    "react-scripts": "^5.0.0",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.6.2"
  }
}
