{
  "name": "backend",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "nodemon --exec 'NODE_ENV=dev ts-node src/index.ts'",
    "build": "tsc",
    "pretty": "prettier --write .",
    "lint": "eslint --max-warnings 0 --ext .ts,.tsx . && tsc --noEmit"
  },
  "prettier": {
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "printWidth": 119,
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5"
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "rules": {
      "@typescript-eslint/no-inferrable-types": "off",
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "ignorePatterns": [
      "build",
      "node_modules"
    ]
  },
  "nodemonConfig": {
    "ext": "ts,tsx,json",
    "watch": [
      "**/*"
    ]
  },
  "dependencies": {
    "aws-sdk": "^2.1138.0",
    "axios": "^0.27.2",
    "cognito-express": "^3.0.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.1",
    "morgan": "^1.10.0",
    "postgres": "^3.2.2",
    "verror": "^1.10.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.13",
    "@types/morgan": "^1.9.3",
    "@types/node": "^17.0.33",
    "@types/verror": "^1.10.5",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "eslint": "^8.15.0",
    "nodemon": "^2.0.16",
    "prettier": "^2.6.2",
    "ts-node": "^10.7.0",
    "typescript": "^4.6.4"
  }
}
